  </div>

  <!-- MODAL -->
  <div id="modal-overlay">
    <div id="modal">
      <div class="modal-header">
        <div class="modal-header-info">
          <h3 id="modal-titulo">Historico de Movimentacoes</h3>
          <span id="modal-subtitulo"></span>
        </div>
        <button id="btn-fechar-modal" title="Fechar">&#10005;</button>
      </div>

      <div id="modal-filtro-datas">
        <label>De</label><input type="date" id="filtro-data-ini" />
        <label>Ate</label><input type="date" id="filtro-data-fim" />
        <button id="btn-filtrar-datas">Buscar periodo</button>
        <span id="modal-resumo"></span>
      </div>

      <!-- BARRA DE PROGRESSO DA BUSCA -->
      <div id="barra-progresso-wrap">
        <div id="barra-progresso-texto">
          <span id="barra-progresso-label">Buscando movimentacoes...</span>
          <span id="barra-progresso-pct">0%</span>
        </div>
        <div id="barra-progresso-bar-outer">
          <div id="barra-progresso-bar-inner"></div>
        </div>
      </div>

      <div id="modal-body">
        <table id="tabela-mov">
          <thead><tr>
            <th>Data</th><th>Cliente/Fornecedor</th><th>Tipo</th><th>Qtd</th><th>Descricao</th>
          </tr></thead>
          <tbody id="tbody-mov">
            <tr><td colspan="5" class="modal-status">Carregando...</td></tr>
          </tbody>
        </table>
      </div>
