  <!-- CARRINHO -->
  <div id="carrinho-float">
    <div id="carrinho-painel" class="minimizado">
      <div class="carrinho-header">
        <h2>Carrinho</h2>
        <span id="qtd-itens">0 itens</span>
      </div>
      <div id="lista-carrinho"></div>
      <div class="carrinho-footer">
        <div class="acoes-carrinho">
          <button id="btn-copiar">&#128203; Copiar pedido</button>
          <button id="btn-limpar">Limpar carrinho</button>
        </div>
      </div>
    </div>
    <button id="btn-toggle-carrinho">
      &#128722; Carrinho
      <span id="badge-float"></span>
      <span id="seta-toggle">&#9650;</span>
    </button>
  </div>

  <div id="toast"></div>

  <script>
    const lojaIdJeta = "361408";
    let todosProdutos    = [];
    let produtosFiltrados = [];
    let carrinho          = {};
    let carrinhoAberto    = false;

    /* ── CACHE DE MOVIMENTAÇÕES ──────────────────────────────────────────────
       Evita rebuscar vendas/compras quando o usuário filtra só datas já
       carregadas. O cache guarda vendas e compras separadamente por produto.
    ─────────────────────────────────────────────────────────────────────── */
    const _cacheVendas  = {};  // { produtoId: { ts: timestamp, data: [...] } }
    const _cacheCompras = {};
    const CACHE_TTL_MS  = 5 * 60 * 1000; // 5 minutos

    function _cacheValido(map, id) {
      return map[id] && (Date.now() - map[id].ts) < CACHE_TTL_MS;
    }

    /* ── PROGRESS BAR HELPERS ────────────────────────────────────────────── */
    function _showProgress(label) {
      const wrap = document.getElementById('barra-progresso-wrap');
      document.getElementById('barra-progresso-label').textContent = label || 'Buscando...';
      document.getElementById('barra-progresso-pct').textContent   = '0%';
      document.getElementById('barra-progresso-bar-inner').style.width = '0%';
      wrap.classList.add('visivel');
    }
    function _setProgress(pct, label) {
      document.getElementById('barra-progresso-bar-inner').style.width = pct + '%';
      document.getElementById('barra-progresso-pct').textContent = Math.round(pct) + '%';
      if (label) document.getElementById('barra-progresso-label').textContent = label;
    }
    function _hideProgress() {
      document.getElementById('barra-progresso-wrap').classList.remove('visivel');
    }

    /* ── FORMATAÇÃO DE DATA ──────────────────────────────────────────────── */
    function formatarData(s) {
      if (!s || s === "null" || s === "") return '<span class="sem-registro">\u2014</span>';
      try {
        const p = s.split(' '), d = p[0].split('-');
        if (d.length !== 3) return s;
        const h = p[1] ? p[1].substring(0,5) : '';
        return d[2]+'/'+d[1]+'/'+d[0]+(h?' '+h:'');
      } catch(e){ return s; }
    }

    /* ── BUSCA DE PRODUTOS ───────────────────────────────────────────────── */
    async function buscarProdutos(nome, pag) {
      const url = new URL("https://caixa-three.vercel.app/api/produtos");
      url.searchParams.append("loja_id", lojaIdJeta);
      url.searchParams.append("limite", "100");
      url.searchParams.append("pagina", pag || 1);
      if ((nome || "").trim()) url.searchParams.append("nome", nome.trim());
      return await (await fetch(url.toString())).json();
    }

    async function carregarProdutos(nome) {
      nome = nome || "";
      document.getElementById('card-com-estoque').style.display = 'none';
      document.getElementById('card-sem-estoque').style.display = 'none';
      const ph = document.getElementById('card-placeholder');
      ph.style.display = 'block';
      ph.querySelector('td').textContent = 'Carregando...';
      ph.querySelector('td').className   = 'status-msg';
      document.getElementById('container-filtro').style.display = 'none';
      todosProdutos = [];
      let pag = 1, tot = 1;
      try {
        do {
          const d = await buscarProdutos(nome, pag);
          if (d.code !== 200) throw new Error("Erro ao carregar produtos.");
          todosProdutos = todosProdutos.concat(d.data.filter(function(p){ return p.nome; }));
          tot = d.meta.total_paginas; pag++;
        } while (pag <= tot);
        todosProdutos.sort(function(a,b){ return a.nome.localeCompare(b.nome); });
        renderizarTabela(todosProdutos);
        document.getElementById('container-filtro').style.display = 'block';
      } catch(err) {
        ph.style.display = 'block';
        ph.querySelector('td').textContent = err.message;
        ph.querySelector('td').className   = 'status-msg erro';
      }
    }

    /* ── ATUALIZAR CÉLULA DE DATA NA TABELA ─────────────────────────────── */
    function atualizarCelulaData(nomeProduto, dataStr) {
      document.querySelectorAll('.tabela-produtos-base tbody tr').forEach(function(linha){
        const td = linha.querySelector('td:first-child');
        if (td && td.getAttribute('title') === nomeProduto) {
          const c = linha.querySelectorAll('td')[2];
          if (c) c.innerHTML = formatarData(dataStr);
        }
      });
    }

    /* ── CRIAR LINHA DE PRODUTO ─────────────────────────────────────────── */
    function criarLinhaProduto(produto) {
      const id   = produto.id || produto.nome;
      const ecls = produto.estoque > 0 ? 'tag-estoque-ok' : 'tag-estoque-zero';
      const sem  = produto.estoque <= 0;
      const tr   = document.createElement('tr');
      tr.className = 'clicavel';
      tr.innerHTML =
        '<td title="'+produto.nome+'">'+produto.nome+'</td>'+
        '<td class="'+ecls+'">'+produto.estoque+'</td>'+
        '<td><button class="btn-add" data-id="'+id+'"'+(sem?' disabled':'')+'>+</button></td>';
      tr.addEventListener('click', function(e){
        if (e.target.closest('.btn-add')) return;
        abrirHistorico(produto);
      });
      tr.querySelector('.btn-add').addEventListener('click', function(){
        const p = todosProdutos.find(function(x){ return (x.id||x.nome) == id; });
        if (p) adicionarAoCarrinho(p);
      });
      return tr;
    }

    /* ── RENDERIZAR TABELA (COM/SEM ESTOQUE) ────────────────────────────── */
    function renderizarTabela(produtos) {
      produtosFiltrados = produtos;
      const com  = produtos.filter(function(p){ return p.estoque > 0; });
      const sem  = produtos.filter(function(p){ return p.estoque <= 0; });
      const ph   = document.getElementById('card-placeholder');
      const cCom = document.getElementById('card-com-estoque');
      const cSem = document.getElementById('card-sem-estoque');
      const bCom = document.getElementById('tbody-com-estoque');
      const bSem = document.getElementById('tbody-sem-estoque');
      ph.style.display = 'none';
      if (!produtos.length) {
        bCom.innerHTML = bSem.innerHTML = '';
        cCom.style.display = cSem.style.display = 'none';
        ph.style.display = 'block';
        ph.querySelector('td').textContent = 'Nenhum produto encontrado.';
        return;
      }
      bCom.innerHTML = '';
      if (com.length) {
        cCom.style.display = 'block';
        document.getElementById('count-com-estoque').textContent = com.length+' produto'+(com.length!==1?'s':'');
        com.forEach(function(p){ bCom.appendChild(criarLinhaProduto(p)); });
      } else { cCom.style.display = 'none'; }
      bSem.innerHTML = '';
      if (sem.length) {
        cSem.style.display = 'block';
        document.getElementById('count-sem-estoque').textContent = sem.length+' produto'+(sem.length!==1?'s':'');
        sem.forEach(function(p){ bSem.appendChild(criarLinhaProduto(p)); });
      } else { cSem.style.display = 'none'; }
    }

    /* ── FILTRO LOCAL ───────────────────────────────────────────────────── */
    function filtrarTabela() {
      const t = document.getElementById('campo-filtro').value.toLowerCase().trim();
      renderizarTabela(todosProdutos.filter(function(p){ return p.nome.toLowerCase().includes(t); }));
    }

    /* ── ORDENAÇÃO ──────────────────────────────────────────────────────── */
    function ordenarTabela(col, ord) {
      if (!produtosFiltrados.length) return;
      const s = produtosFiltrados.slice().sort(function(a,b){
        const vA = a[col] != null ? a[col] : '', vB = b[col] != null ? b[col] : '';
        if (col === 'estoque') return ord === 'asc' ? Number(vA)-Number(vB) : Number(vB)-Number(vA);
        return ord === 'asc' ? vA.toString().localeCompare(vB.toString()) : vB.toString().localeCompare(vA.toString());
      });
      renderizarTabela(s);
    }

    function setupOrdenacao(tbl) {
      tbl.querySelectorAll('th[data-coluna]').forEach(function(th){
        th.addEventListener('click', function(){
          const col  = th.dataset.coluna;
          const nova = (th.dataset.ordem || 'asc') === 'asc' ? 'desc' : 'asc';
          document.querySelectorAll('.tabela-produtos-base th').forEach(function(t){
            t.classList.remove('ordenado-asc','ordenado-desc');
            t.dataset.ordem = 'asc';
          });
          th.classList.add(nova === 'asc' ? 'ordenado-asc' : 'ordenado-desc');
          th.dataset.ordem = nova;
          ordenarTabela(col, nova);
        });
      });
    }

    /* ── CARRINHO ───────────────────────────────────────────────────────── */
    function toggleCarrinho() {
      carrinhoAberto = !carrinhoAberto;
      document.getElementById('carrinho-painel').classList.toggle('minimizado', !carrinhoAberto);
      document.getElementById('seta-toggle').classList.toggle('aberto', carrinhoAberto);
    }

    function adicionarAoCarrinho(produto) {
      const id = produto.id || produto.nome;
      if (carrinho[id]) {
        if (carrinho[id].qty >= produto.estoque) { mostrarToast('Estoque insuficiente'); return; }
        carrinho[id].qty++;
      } else {
        carrinho[id] = { produto: produto, qty: 1 };
        if (!carrinhoAberto) toggleCarrinho();
      }
      atualizarCarrinho();
      const n = produto.nome;
      mostrarToast('"'+(n.length>28 ? n.substring(0,28)+'\u2026' : n)+'" adicionado');
    }

    function alterarQtd(id, delta) {
      if (!carrinho[id]) return;
      carrinho[id].qty += delta;
      if (carrinho[id].qty <= 0) {
        delete carrinho[id];
      } else if (carrinho[id].qty > carrinho[id].produto.estoque) {
        carrinho[id].qty = carrinho[id].produto.estoque;
        mostrarToast('Limite de estoque atingido');
      }
      atualizarCarrinho();
    }

    function removerItem(id)  { delete carrinho[id]; atualizarCarrinho(); }
    function limparCarrinho() { carrinho = {};        atualizarCarrinho(); }

    function atualizarCarrinho() {
      const lista = document.getElementById('lista-carrinho');
      const itens = Object.entries(carrinho);
      const tot   = itens.reduce(function(a,kv){ return a + kv[1].qty; }, 0);
      const badge = document.getElementById('badge-float');
      badge.textContent = tot;
      badge.classList.toggle('visivel', tot > 0);
      document.getElementById('qtd-itens').textContent = tot+' '+(tot === 1 ? 'item' : 'itens');
      lista.innerHTML = '';
      itens.forEach(function(kv){
        const id=kv[0], p=kv[1].produto, q=kv[1].qty;
        const div = document.createElement('div');
        div.className = 'item-carrinho';
        div.innerHTML =
          '<div class="item-nome" title="'+p.nome+'">'+p.nome+'</div>'+
          '<div class="qty-control">'+
            '<button class="qty-btn" data-id="'+id+'" data-delta="-1">\u2212</button>'+
            '<span class="qty-num">'+q+'</span>'+
            '<button class="qty-btn" data-id="'+id+'" data-delta="1">+</button>'+
          '</div>'+
          '<button class="btn-remover" data-id="'+id+'">\u2715</button>';
        lista.appendChild(div);
      });
      lista.querySelectorAll('.qty-btn').forEach(function(b){
        b.addEventListener('click', function(){ alterarQtd(b.dataset.id, parseInt(b.dataset.delta)); });
      });
      lista.querySelectorAll('.btn-remover').forEach(function(b){
        b.addEventListener('click', function(){ removerItem(b.dataset.id); });
      });
    }

    function copiarPedido() {
      const itens = Object.values(carrinho);
      if (!itens.length) { mostrarToast('O carrinho esta vazio'); return; }
      const linhas = itens.map(function(v){ return '\u2022 '+v.produto.nome+' \u2014 '+v.qty+'x'; });
      const texto  = 'PEDIDO \u2014 '+new Date().toLocaleDateString('pt-BR')+'\n'+'\u2500'.repeat(40)+'\n'+linhas.join('\n');
      navigator.clipboard.writeText(texto).then(function(){
        const btn = document.getElementById('btn-copiar');
        btn.textContent = '\u2705 Copiado!';
        btn.classList.add('copiado');
        setTimeout(function(){ btn.innerHTML='&#128203; Copiar pedido'; btn.classList.remove('copiado'); }, 2000);
      }).catch(function(){ mostrarToast('Erro ao copiar.'); });
    }

    /* ── MOVIMENTAÇÕES ──────────────────────────────────────────────────── */
    let _produtoAtual = null, _todasMovs = [];

    function setDatasDefault() {
      const h = new Date(), a = new Date();
      a.setDate(h.getDate()-90);
      document.getElementById('filtro-data-ini').value = a.toISOString().substring(0,10);
      document.getElementById('filtro-data-fim').value = h.toISOString().substring(0,10);
    }

    function renderMovs(movs) {
      const tbody = document.getElementById('tbody-mov');
      const ent = movs.filter(function(m){ return  m.isEntrada; }).reduce(function(s,m){ return s+(m.qtd||0); }, 0);
      const sai = movs.filter(function(m){ return !m.isEntrada; }).reduce(function(s,m){ return s+(m.qtd||0); }, 0);
      document.getElementById('modal-resumo').innerHTML = movs.length
        ? '<span class="mov-entrada">+'+ent+' entrada'+(ent!==1?'s':'')+'</span>&nbsp;&nbsp;'+
          '<span class="mov-saida">\u2212'+sai+' sa\u00edda'+(sai!==1?'s':'')+'</span>&nbsp;&nbsp;('+movs.length+' reg.)'
        : '';
      if (!movs.length) {
        tbody.innerHTML = '<tr><td colspan="5" class="modal-status">Nenhuma movimentacao encontrada no periodo.</td></tr>';
        return;
      }
      /* ── Renderização em fragment (evita reflow por item) ── */
      const frag = document.createDocumentFragment();
      movs.forEach(function(mov){
        const tc = mov.isEntrada ? 'mov-entrada' : 'mov-saida';
        const s  = mov.isEntrada ? '+' : '\u2212';
        const tr = document.createElement('tr');
        tr.innerHTML =
          '<td style="white-space:nowrap">'+formatarData(mov.dataISO+(mov.hora?' '+mov.hora:''))+'</td>'+
          '<td>'+mov.cliente+'</td>'+
          '<td style="text-align:center"><span class="'+tc+'">'+(mov.isEntrada?'Entrada':'Sa\u00edda')+'</span></td>'+
          '<td style="text-align:center" class="'+tc+'">'+(mov.qtd!==null ? s+mov.qtd : '<span style="color:var(--text-muted)">\u2014</span>')+'</td>'+
          '<td style="font-size:11px;color:var(--text-secondary)">'+mov.descricao+'</td>';
        frag.appendChild(tr);
      });
      tbody.innerHTML = '';
      tbody.appendChild(frag);
    }

    /* ── BUSCA COM PAGINAÇÃO — COM CACHE E PROGRESSO ────────────────────
       PROBLEMA ORIGINAL: buscarTodasPaginas fazia fetch sequencial de
       todas as páginas a cada busca, bloqueando por segundos.

       CORREÇÃO:
       1. Cache de 5 min por produto/rota (evita refetch desnecessário)
       2. Paralelismo: vendas e compras buscam ao mesmo tempo
       3. Dentro de cada rota: pages em paralelo (Promise.all por lote)
       4. Barra de progresso visual para o usuário não achar que travou
    ─────────────────────────────────────────────────────────────────── */
    async function buscarTodasPaginasComCache(rota, produtoId, di, df) {
      /* Chave: inclui datas para não servir cache com período diferente */
      const cacheKey = produtoId + '|' + (di||'') + '|' + (df||'');
      const cacheMap = rota === 'vendas' ? _cacheVendas : _cacheCompras;

      if (cacheMap[cacheKey] && (Date.now() - cacheMap[cacheKey].ts) < CACHE_TTL_MS) {
        return cacheMap[cacheKey].data;
      }

      const base = 'https://caixa-three.vercel.app/api/proxy';
      /* Busca a página 1 para descobrir total de páginas */
      const params1 = new URLSearchParams({ rota: rota, loja_id: lojaIdJeta, limite: 100, pagina: 1 });
      if (di) params1.append('data_inicio', di);
      if (df) params1.append('data_fim',    df);

      const r1 = await fetch(base + '?' + params1).then(function(x){ return x.json(); }).catch(function(){ return null; });
      if (!r1 || r1.code !== 200 || !r1.data) return [];

      const todos = r1.data.slice();
      const totalPags = (r1.meta && r1.meta.total_paginas) || 1;

      if (totalPags > 1) {
        /* Busca as demais páginas todas em paralelo */
        const restantes = [];
        for (let p = 2; p <= totalPags; p++) {
          const params = new URLSearchParams({ rota: rota, loja_id: lojaIdJeta, limite: 100, pagina: p });
          if (di) params.append('data_inicio', di);
          if (df) params.append('data_fim',    df);
          restantes.push(
            fetch(base + '?' + params)
              .then(function(x){ return x.json(); })
              .catch(function(){ return null; })
          );
        }
        const resultados = await Promise.all(restantes);
        resultados.forEach(function(r){
          if (r && r.code === 200 && r.data) todos.push.apply(todos, r.data);
        });
      }

      cacheMap[cacheKey] = { ts: Date.now(), data: todos };
      return todos;
    }

    async function buscarMovimentacoesPeriodo(produto, di, df) {
      const pid = String(produto.id);

      _showProgress('Buscando vendas e compras...');
      _setProgress(5);

      /* Busca vendas e compras em PARALELO */
      let vendasProm   = buscarTodasPaginasComCache('vendas',  pid+'|'+di+'|'+df, di, df);
      let comprasProm  = buscarTodasPaginasComCache('compras', pid+'|'+di+'|'+df, di, df);

      /* Pequeno tick para que a barra apareça antes de bloquear */
      await new Promise(function(r){ setTimeout(r, 0); });
      _setProgress(15, 'Aguardando vendas e compras...');

      const res = await Promise.all([vendasProm, comprasProm]);
      _setProgress(80, 'Processando resultados...');

      const movs = [];

      res[0].forEach(function(v){
        const its = (v.produtos||[]).filter(function(p){ return p.produto && String(p.produto.produto_id) === pid; });
        if (!its.length) return;
        const q  = its.reduce(function(s,p){ return s + Number(p.produto.quantidade||1); }, 0);
        const ts = v.cadastrado_em || v.data || '', pp = ts.split(' ');
        movs.push({
          dataISO:   pp[0] || '',
          hora:      pp[1] ? pp[1].substring(0,5) : '',
          cliente:   v.nome_cliente || '\u2014',
          qtd:       q,
          descricao: 'Venda n\u00ba ' + v.codigo,
          isEntrada: false
        });
      });

      res[1].forEach(function(c){
        const its = (c.produtos||[]).filter(function(p){ return p.produto && String(p.produto.produto_id) === pid; });
        if (!its.length) return;
        const q  = its.reduce(function(s,p){ return s + Number(p.produto.quantidade||1); }, 0);
        const ts = c.cadastrado_em || c.data || '', pp = ts.split(' ');
        movs.push({
          dataISO:   pp[0] || '',
          hora:      pp[1] ? pp[1].substring(0,5) : '',
          cliente:   c.nome_fornecedor || c.nome_cliente || '\u2014',
          qtd:       q,
          descricao: 'Compra n\u00ba ' + (c.codigo || c.id),
          isEntrada: true
        });
      });

      /* Entrada manual por modificação */
      if (produto.modificado_em && produto.cadastrado_em && produto.modificado_em !== produto.cadastrado_em) {
        const pe = produto.modificado_em.split(' '), de = pe[0];
        if ((!di||de>=di) && (!df||de<=df) && !movs.some(function(m){ return m.dataISO===de && m.isEntrada; }))
          movs.push({
            dataISO:   de,
            hora:      pe[1] ? pe[1].substring(0,5) : '',
            cliente:   '\u2014',
            qtd:       null,
            descricao: 'Entrada realizada manualmente',
            isEntrada: true
          });
      }

      movs.sort(function(a,b){
        return (b.dataISO + b.hora).localeCompare(a.dataISO + a.hora);
      });

      _setProgress(100);
      await new Promise(function(r){ setTimeout(r, 180); });
      _hideProgress();

      return movs;
    }

    /* ── ABRIR MODAL ────────────────────────────────────────────────────── */
    async function abrirHistorico(produto) {
      _produtoAtual = produto;
      const ov  = document.getElementById('modal-overlay');
      const tb  = document.getElementById('tbody-mov');
      document.getElementById('modal-titulo').textContent    = produto.nome;
      document.getElementById('modal-subtitulo').textContent = 'Estoque atual: '+produto.estoque+' un.';
      tb.innerHTML = '<tr><td colspan="5" class="modal-status">Carregando...</td></tr>';
      document.getElementById('modal-resumo').textContent = '';
      setDatasDefault();
      ov.classList.add('visivel');
      document.body.style.overflow = 'hidden';
      try {
        const ini = document.getElementById('filtro-data-ini').value;
        const fim = document.getElementById('filtro-data-fim').value;
        _todasMovs = await buscarMovimentacoesPeriodo(produto, ini, fim);
        if (_todasMovs.length) {
          const ud = _todasMovs[0].dataISO + (_todasMovs[0].hora ? ' '+_todasMovs[0].hora : '');
          atualizarCelulaData(produto.nome, ud);
        }
        renderMovs(_todasMovs);
      } catch(e) {
        _hideProgress();
        tb.innerHTML = '<tr><td colspan="5" class="modal-status erro">Erro: '+e.message+'</td></tr>';
      }
    }

    async function buscarPeriodo() {
      if (!_produtoAtual) return;
      const tb  = document.getElementById('tbody-mov');
      const ini = document.getElementById('filtro-data-ini').value;
      const fim = document.getElementById('filtro-data-fim').value;
      tb.innerHTML = '<tr><td colspan="5" class="modal-status">Buscando...</td></tr>';
      document.getElementById('modal-resumo').textContent = '';
      try {
        _todasMovs = await buscarMovimentacoesPeriodo(_produtoAtual, ini, fim);
        renderMovs(_todasMovs);
      } catch(e) {
        _hideProgress();
        tb.innerHTML = '<tr><td colspan="5" class="modal-status erro">Erro: '+e.message+'</td></tr>';
      }
    }

    function fecharModal() {
      document.getElementById('modal-overlay').classList.remove('visivel');
      document.body.style.overflow = '';
    }

    /* ── TOAST ──────────────────────────────────────────────────────────── */
    let toastTimer;
    function mostrarToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.add('visivel');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(function(){ t.classList.remove('visivel'); }, 2200);
    }

    /* ── EVENTOS ────────────────────────────────────────────────────────── */
    document.getElementById('btn-fechar-modal').addEventListener('click', fecharModal);
    document.getElementById('btn-filtrar-datas').addEventListener('click', buscarPeriodo);
    document.getElementById('filtro-data-ini').addEventListener('keypress', function(e){ if(e.key==='Enter') buscarPeriodo(); });
    document.getElementById('filtro-data-fim').addEventListener('keypress', function(e){ if(e.key==='Enter') buscarPeriodo(); });
    setupOrdenacao(document.getElementById('tabela-produtos'));
    setupOrdenacao(document.getElementById('tabela-produtos-zero'));
    document.getElementById('modal-overlay').addEventListener('click', function(e){
      if (e.target === document.getElementById('modal-overlay')) fecharModal();
    });
    document.addEventListener('keydown', function(e){ if (e.key==='Escape') fecharModal(); });
    document.getElementById('btn-buscar').addEventListener('click', function(){
      carregarProdutos(document.getElementById('campo-busca').value);
    });
    document.getElementById('campo-busca').addEventListener('keypress', function(e){
      if (e.key === 'Enter') document.getElementById('btn-buscar').click();
    });
    document.getElementById('campo-filtro').addEventListener('input', filtrarTabela);
    document.getElementById('btn-copiar').addEventListener('click', copiarPedido);
    document.getElementById('btn-limpar').addEventListener('click', limparCarrinho);
    document.getElementById('btn-toggle-carrinho').addEventListener('click', toggleCarrinho);

    atualizarCarrinho();
  </script>
</body>
</html>
